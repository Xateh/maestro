{
  "name": "maestro-orchestrator",
  "version": "0.1.0",
  "description": "Multi-agent plan→execute→review orchestrator built on LangGraph",
  "type": "module",
  "engines": {
    "node": ">=22.5"
  },
  "bin": {
    "maestro": "bin/maestro.mjs"
  },
  "exports": {
    ".": "./bin/maestro.mjs",
    "./mcp": "./src/mcp/server.mjs"
  },
  "files": [
    "bin/",
    "src/"
  ],
  "scripts": {
    "maestro": "node bin/maestro.mjs",
    "maestro:mcp": "node src/mcp/server.mjs",
    "test": "node --test test/maestro-package.test.mjs test/maestro-mcp.test.mjs test/maestro.test.mjs test/maestro-engine.test.mjs test/maestro-herdr-runner.test.mjs",
    "test:package": "node --test test/maestro-package.test.mjs",
    "test:maestro": "node --test test/maestro.test.mjs",
    "test:mcp": "node --test test/maestro-mcp.test.mjs",
    "test:enterprise": "npm run test:package && npm run test:maestro && npm run test:mcp",
    "lint": "biome lint .",
    "headroom:setup": "bash scripts/headroom-setup.sh"
  },
  "dependencies": {
    "@langchain/langgraph": "^1.3.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex": "^0.133.0",
    "headroom-ai": "^0.22.4",
    "liquidjs": "^10.25.7",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16"
  }
}
