{
  "name": "maestro-orchestrator",
  "version": "0.1.0",
  "description": "Multi-agent plan→execute→review orchestrator built on LangGraph",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xateh/maestro.git"
  },
  "license": "MIT",
  "author": "Xateh",
  "keywords": [
    "agents",
    "multi-agent",
    "orchestrator",
    "langgraph",
    "claude",
    "codex",
    "cli",
    "workflow",
    "mcp"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.13"
  },
  "bin": {
    "maestro": "bin/maestro.mjs"
  },
  "exports": {
    ".": "./bin/maestro.mjs",
    "./mcp": "./src/mcp/server.mjs"
  },
  "files": [
    "bin/",
    "src/"
  ],
  "scripts": {
    "maestro": "node bin/maestro.mjs",
    "maestro:mcp": "node src/mcp/server.mjs",
    "test": "node --test test/maestro-package.test.mjs test/maestro-mcp.test.mjs test/maestro.test.mjs test/maestro-engine.test.mjs test/maestro-herdr-runner.test.mjs test/maestro-tui-app.test.mjs test/maestro-setup.test.mjs test/maestro-ollama.test.mjs test/maestro-cli-registry.test.mjs test/maestro-init.test.mjs test/maestro-cli-args.test.mjs test/maestro-secret-crypto.test.mjs",
    "test:package": "node --test test/maestro-package.test.mjs",
    "test:maestro": "node --test test/maestro.test.mjs",
    "test:mcp": "node --test test/maestro-mcp.test.mjs",
    "test:ollama": "node --test test/maestro-ollama.test.mjs",
    "agent:ocr": "node scripts/local-agents.mjs ocr",
    "agent:eval": "node scripts/local-agents.mjs eval",
    "test:enterprise": "npm run test:package && npm run test:maestro && npm run test:mcp",
    "lint": "biome lint .",
    "prepublishOnly": "npm run lint && npm test",
    "test:coverage": "c8 npm test",
    "headroom:setup": "bash scripts/headroom-setup.sh"
  },
  "dependencies": {
    "@langchain/langgraph": "^1.3.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex": "^0.133.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.219.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "headroom-ai": "^0.22.4",
    "liquidjs": "^10.25.7",
    "pg": "^8.21.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "c8": "11.0.0"
  }
}
